# =========================================================================
# Конфиг Supabase для serverless API.
# Скопируйте этот файл в `.env` и заполните своими реальными данными.
# В Vercel: Project Settings → Environment Variables — добавьте те же ключи.
# =========================================================================

# URL проекта Supabase (Settings → API → Project URL)
SUPABASE_URL=https://wncrwcxobiisiwwtmcuo.supabase.co

# Анонимный (публичный) ключ — отдаётся браузеру через /api/config
# (Settings → API → Project API keys → anon / public)
SUPABASE_ANON_KEY=sb_publishable_DJKTRkPjxDOVs7T8yWmUiA_Z-dbgigc

# Сервисный ключ — ТОЛЬКО для serverless-функций /api/*, НИКОГДА не отдавайте в браузер
# (Settings → API → Project API keys → service_role / secret)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_po-pRTxdJzHdTso8Hp8GGQ_yeYIHQTc

# Email администратора, который создали в Authentication → Users
SUPABASE_ADMIN_EMAIL=semikovnikita2007@gmail.com

# Пароль администратора (для формы логина; на сервере используется только email,
# пароль проходит через Supabase Auth, не хранится в нашем env)
SUPABASE_ADMIN_PASSWORD=77619532Qweqw
