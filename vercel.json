{
  "version": 2,
  "buildCommand": null,
  
  "rewrites": [
    { "source": "/api/requests", "destination": "/api/requests.mjs" },
    { "source": "/api/config", "destination": "/api/config.mjs" }
  ],
  "redirects": [
    { "source": "/admin", "destination": "/admin/", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
